<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Maya Bazaar Restaurant – Perundurai's Finest Dining</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;0,900;1,500;1,700&family=Jost:wght@300;400;500;600&family=Great+Vibes&display=swap" rel="stylesheet"/>
<style>
:root {
  --burg:     #4a0f1a;
  --burg-d:   #2e0810;
  --saff:     #e8821a;
  --saff-lt:  #f5a444;
  --saff-pale:#fdf0e0;
  --ivory:    #faf6f0;
  --cream:    #f5ede0;
  --spice:    #c0521a;
  --spice-dk: #8b3510;
  --turm:     #d4a017;
  --td:       #1c0a05;
  --tm:       #5a3020;
  --tl:       #9a7060;
  --border:   rgba(200,100,30,.18);
  --shad:     0 8px 40px rgba(74,15,26,.12);
  --shad-lg:  0 24px 80px rgba(74,15,26,.22);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Jost',sans-serif;background:var(--ivory);color:var(--td);overflow-x:hidden}
h1,h2,h3{font-family:'Playfair Display',serif}

/* NAV */
nav{
  position:fixed;top:0;left:0;right:0;z-index:999;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 5vw;height:66px;
  background:rgba(46,8,16,.97);backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(232,130,26,.2);
}
.nlogo{
  font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;
  color:var(--saff-lt);letter-spacing:.04em;text-decoration:none;
  display:flex;align-items:center;gap:.45rem;
}
.nlogo .sc{font-family:'Great Vibes',cursive;font-size:1.95rem;color:var(--saff);line-height:1}
.nlinks{display:flex;gap:2rem;list-style:none}
.nlinks a{color:rgba(250,246,240,.58);font-size:.8rem;font-weight:500;text-decoration:none;
  letter-spacing:.1em;text-transform:uppercase;transition:color .2s}
.nlinks a:hover{color:var(--saff-lt)}
.ncta{
  background:linear-gradient(135deg,var(--saff),var(--spice));
  color:#fff;font-size:.77rem;font-weight:600;letter-spacing:.1em;
  text-transform:uppercase;padding:.5rem 1.4rem;border-radius:2px;
  text-decoration:none;transition:all .2s;
  box-shadow:0 3px 16px rgba(232,130,26,.4);white-space:nowrap;
}
.ncta:hover{transform:translateY(-1px);box-shadow:0 6px 24px rgba(232,130,26,.5)}
.ham{display:none;flex-direction:column;gap:5px;cursor:pointer}
.ham span{width:24px;height:2px;background:var(--saff);border-radius:2px}
.mobnav{
  display:none;position:fixed;top:66px;left:0;right:0;z-index:998;
  background:rgba(22,4,8,.99);padding:1.5rem 5vw 2rem;
  flex-direction:column;gap:1.1rem;
  border-bottom:1px solid rgba(232,130,26,.2);
}
.mobnav.open{display:flex}
.mobnav a{color:rgba(250,246,240,.6);font-size:.92rem;text-decoration:none;
  padding:.45rem 0;border-bottom:1px solid rgba(255,255,255,.05)}
.mobnav a:hover{color:var(--saff-lt)}
@media(max-width:768px){.nlinks,.ncta{display:none}.ham{display:flex}}

/* HERO */
.hero{
  min-height:100vh;position:relative;
  display:flex;align-items:center;overflow:hidden;
  padding:80px 5vw 60px;
}
.h-photo{position:absolute;inset:0;background:var(--burg-d)}
.h-photo img{width:100%;height:100%;object-fit:cover;object-position:center;display:block}
.h-ov{
  position:absolute;inset:0;
  background:
    linear-gradient(105deg,rgba(46,8,16,.94) 0%,rgba(46,8,16,.72) 45%,rgba(46,8,16,.38) 100%),
    linear-gradient(to top,rgba(46,8,16,.9) 0%,transparent 60%);
}
.h-grain{
  position:absolute;inset:0;opacity:.05;
  background-image:
    radial-gradient(circle at 25% 25%,var(--saff) 1px,transparent 1px),
    radial-gradient(circle at 75% 75%,var(--turm) 1px,transparent 1px);
  background-size:44px 44px,66px 66px;
}
.h-content{position:relative;z-index:2;max-width:620px;animation:rise .85s .1s both}
.h-pill{
  display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(232,130,26,.16);border:1px solid rgba(232,130,26,.38);
  border-radius:100px;padding:.36rem 1.05rem;color:var(--saff-lt);
  font-size:.73rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;
  margin-bottom:1.7rem;animation:rise .85s .15s both;
}
.h-title{
  font-size:clamp(2.8rem,8vw,5.8rem);font-weight:900;
  line-height:1.0;color:#fff;margin-bottom:1rem;
  animation:rise .85s .22s both;
}
.h-title .l2{
  font-style:italic;display:block;
  background:linear-gradient(100deg,var(--saff),var(--turm));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.h-sub{
  font-size:1rem;line-height:1.75;color:rgba(250,246,240,.62);
  max-width:460px;margin-bottom:2.4rem;font-weight:300;
  animation:rise .85s .3s both;
}
.h-btns{display:flex;flex-wrap:wrap;gap:1rem;animation:rise .85s .38s both}
.btn-fire{
  display:inline-flex;align-items:center;gap:.6rem;
  background:linear-gradient(135deg,var(--saff),var(--spice));
  color:#fff;font-weight:600;font-size:.86rem;
  letter-spacing:.08em;text-transform:uppercase;
  padding:1rem 2.2rem;border-radius:3px;text-decoration:none;
  transition:all .25s;box-shadow:0 6px 24px rgba(232,130,26,.44);
}
.btn-fire:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(232,130,26,.54)}
.btn-ghost{
  display:inline-flex;align-items:center;gap:.6rem;
  border:1.5px solid rgba(250,246,240,.32);
  color:rgba(250,246,240,.82);font-weight:500;font-size:.86rem;
  padding:.95rem 2rem;border-radius:3px;text-decoration:none;transition:all .25s;
}
.btn-ghost:hover{background:rgba(250,246,240,.08);border-color:rgba(250,246,240,.6)}
.h-stats{
  position:absolute;right:5vw;bottom:9%;z-index:2;
  display:flex;flex-direction:column;gap:1.1rem;
  animation:rise .85s .46s both;
}
.sbox{
  background:rgba(46,8,16,.76);border:1px solid rgba(232,130,26,.22);
  backdrop-filter:blur(12px);padding:.95rem 1.35rem;border-radius:4px;
  text-align:center;min-width:96px;
}
.snum{font-family:'Playfair Display',serif;font-size:2.3rem;font-weight:700;color:var(--saff-lt);line-height:1}
.slbl{font-size:.63rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(250,246,240,.38);margin-top:.3rem}
.hscroll{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);z-index:2;animation:bounce 2s infinite}
.hscroll span{display:block;width:1px;height:44px;background:linear-gradient(to bottom,transparent,var(--saff));margin:0 auto}
@keyframes rise{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:translateY(0)}}
@keyframes bounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(8px)}}
@media(max-width:768px){
  .h-stats{position:static;flex-direction:row;margin-top:2.4rem;flex-wrap:wrap}
  .hscroll{display:none}
}

/* TICKER */
.ticker{background:var(--burg-d);padding:.66rem 0;overflow:hidden}
.ttrack{display:flex;gap:3.5rem;animation:tick 24s linear infinite;width:max-content}
.ttrack span{font-size:.73rem;letter-spacing:.12em;text-transform:uppercase;white-space:nowrap;color:rgba(250,240,220,.55)}
.ttrack .dot{color:var(--saff);font-size:.68rem}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* FEAT BAR */
.fbar{display:flex;flex-wrap:wrap;background:linear-gradient(90deg,var(--saff),var(--spice))}
.fitem{
  flex:1;min-width:155px;display:flex;align-items:center;gap:.7rem;
  padding:1.05rem 1.4rem;border-right:1px solid rgba(255,255,255,.15);
}
.fitem:last-child{border-right:none}
.fitem .fi{font-size:1.2rem}
.fil{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.9)}
.fis{font-size:.68rem;color:rgba(255,255,255,.58);margin-top:.1rem}

/* SECTION */
section{padding:86px 5vw}
.stag{font-size:.68rem;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--saff);margin-bottom:.55rem}
.stitle{font-size:clamp(1.85rem,3.8vw,3rem);font-weight:700;line-height:1.15;color:var(--td);margin-bottom:.85rem}
.ssub{font-size:.92rem;color:var(--tl);line-height:1.78;max-width:510px}
.divider{width:54px;height:3px;background:linear-gradient(to right,var(--saff),transparent);margin:1.05rem 0 1.9rem;border-radius:2px}
.reveal{opacity:0;transform:translateY(22px);transition:opacity .65s ease,transform .65s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ABOUT */
.about{background:var(--ivory);display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.a-img{position:relative;border-radius:6px;overflow:hidden;aspect-ratio:4/5;background:var(--burg-d);box-shadow:var(--shad-lg)}
.a-img img{width:100%;height:100%;object-fit:cover;object-position:center;display:block}
.a-img .afall{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  font-family:'Great Vibes',cursive;font-size:4rem;color:var(--saff);opacity:.55;
  background:linear-gradient(160deg,var(--burg-d),var(--spice-dk));
}
.a-strip{
  position:absolute;top:0;left:0;right:0;
  background:linear-gradient(to bottom,rgba(46,8,16,.65),transparent);
  padding:1.15rem;
}
.a-strip .atag{
  display:inline-block;background:var(--saff);color:#fff;
  font-size:.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  padding:.22rem .65rem;border-radius:2px;
}
.a-badge{
  position:absolute;bottom:1.4rem;right:1.4rem;
  background:linear-gradient(135deg,var(--saff),var(--spice));
  color:#fff;padding:.95rem 1.15rem;border-radius:4px;
  text-align:center;box-shadow:var(--shad);
}
.a-badge .big{font-family:'Playfair Display',serif;font-size:2.1rem;font-weight:700;line-height:1}
.a-badge .sm{font-size:.6rem;letter-spacing:.14em;text-transform:uppercase;margin-top:.2rem;opacity:.85}
.a-body p{font-size:.96rem;line-height:1.85;color:var(--tm);margin-bottom:1.25rem}
.pillars{display:flex;flex-wrap:wrap;gap:1.15rem;margin-top:1.7rem}
.pill{display:flex;gap:.65rem;align-items:flex-start}
.pill .ic{font-size:1.25rem;flex-shrink:0;margin-top:.1rem}
.pill-n{font-weight:600;font-size:.82rem;color:var(--td)}
.pill-d{font-size:.76rem;color:var(--tl);margin-top:.15rem}
@media(max-width:900px){
  .about{grid-template-columns:1fr;gap:2.5rem}
  .a-img{aspect-ratio:16/9}
}

/* MENU */
.msec{background:var(--cream)}
.mhead{display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.9rem}
.mtabs{display:flex;gap:.45rem;flex-wrap:wrap;margin-bottom:1.9rem}
.mtab{
  padding:.42rem 1.15rem;border:1.5px solid var(--border);
  border-radius:100px;font-size:.76rem;font-weight:500;
  color:var(--tl);cursor:pointer;transition:all .2s;background:transparent;
}
.mtab.active,.mtab:hover{background:var(--saff);border-color:var(--saff);color:#fff;font-weight:600}
.mgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(268px,1fr));gap:1.35rem}
.mcard{
  background:var(--ivory);border:1px solid var(--border);
  border-radius:6px;overflow:hidden;transition:all .3s;
}
.mcard:hover{transform:translateY(-4px);box-shadow:var(--shad)}
.mci{height:172px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:3rem}
.mci .bg{position:absolute;inset:0;background:linear-gradient(135deg,var(--burg-d),var(--spice-dk));transition:transform .4s}
.mcard:hover .mci .bg{transform:scale(1.05)}
.mci .em{position:relative;z-index:1}
.mci::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(46,8,16,.5),transparent);z-index:0}
.mbadge{
  position:absolute;top:.68rem;left:.68rem;z-index:2;
  background:var(--saff);color:#fff;font-size:.6rem;
  font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  padding:.2rem .58rem;border-radius:2px;
}
.mb{padding:1.05rem}
.mn{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:600;color:var(--td);margin-bottom:.28rem}
.md{font-size:.77rem;color:var(--tl);line-height:1.6;margin-bottom:.82rem}
.mf{display:flex;align-items:center;justify-content:space-between}
.mp{font-family:'Playfair Display',serif;font-size:1.28rem;font-weight:700;color:var(--saff)}
.mt{font-size:.67rem;color:var(--tl);background:var(--cream);padding:.18rem .58rem;border-radius:100px;border:1px solid var(--border)}
.nv{display:inline-block;width:9px;height:9px;border:1.5px solid var(--spice);border-radius:1px;position:relative;margin-right:.32rem;vertical-align:middle}
.nv::after{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:4px;height:4px;background:var(--spice);border-radius:50%}
.vg{display:inline-block;width:9px;height:9px;border:1.5px solid #3a7c3a;border-radius:1px;position:relative;margin-right:.32rem;vertical-align:middle}
.vg::after{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:4px;height:4px;background:#3a7c3a;border-radius:50%}

/* PHOTO FEATURE */
.pfeat{background:var(--burg-d);padding:0;overflow:hidden;position:relative;min-height:400px;display:flex;align-items:center;justify-content:center}
.pfeat img{width:100%;height:100%;object-fit:cover;object-position:center;min-height:400px;display:block}
.pf-ov{
  position:absolute;inset:0;
  background:linear-gradient(90deg,rgba(46,8,16,.9) 0%,rgba(46,8,16,.55) 50%,rgba(46,8,16,.28) 100%);
  display:flex;align-items:center;padding:0 7vw;
}
.pf-c{max-width:500px}
.pf-qm{font-family:'Great Vibes',cursive;font-size:3.4rem;color:var(--saff);line-height:1;margin-bottom:.4rem;display:block}
.pf-t{font-family:'Playfair Display',serif;font-size:clamp(1.35rem,2.8vw,2rem);font-weight:500;font-style:italic;color:#fff;line-height:1.45;margin-bottom:1.4rem}
.pf-s{font-size:.76rem;color:rgba(250,246,240,.48);letter-spacing:.12em;text-transform:uppercase}

/* WHY */
.why{background:var(--burg);position:relative;overflow:hidden}
.why::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 80% at 95% 50%,rgba(232,130,26,.07),transparent),
    radial-gradient(ellipse 40% 60% at 5% 20%,rgba(192,82,26,.09),transparent);
}
.why .stitle{color:#fff}
.why .ssub{color:rgba(250,246,240,.42)}
.why .divider{background:linear-gradient(to right,var(--saff),transparent)}
.wgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(228px,1fr));gap:1.35rem;margin-top:2.7rem;position:relative}
.wcard{
  background:rgba(255,255,255,.04);border:1px solid rgba(232,130,26,.14);
  border-radius:6px;padding:1.75rem 1.45rem;transition:all .3s;position:relative;overflow:hidden;
}
.wcard::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(to right,var(--saff),transparent);opacity:0;transition:opacity .3s}
.wcard:hover{background:rgba(255,255,255,.07);transform:translateY(-3px)}
.wcard:hover::after{opacity:1}
.wicon{font-size:1.85rem;margin-bottom:.85rem}
.wtitle{font-family:'Playfair Display',serif;font-size:1.18rem;font-weight:600;color:var(--saff-lt);margin-bottom:.42rem}
.wtext{font-size:.8rem;color:rgba(250,246,240,.42);line-height:1.72}

/* GALLERY */
.gallery{background:#1a0606;padding:86px 0}
.gi-wrap{padding:0 5vw}
.gallery .stitle{color:#fff}
.gallery .divider{background:linear-gradient(to right,var(--saff),transparent)}
.ggrid{
  display:grid;grid-template-columns:repeat(12,1fr);
  grid-template-rows:repeat(3,170px);
  gap:6px;margin-top:2.4rem;
}
.gi{border-radius:3px;overflow:hidden;position:relative;cursor:pointer;transition:transform .3s}
.gi:hover{transform:scale(1.02);z-index:1}
.gi-bg{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:2.7rem}
.gi::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(26,6,6,.55));opacity:0;transition:opacity .3s}
.gi:hover::after{opacity:1}
.gi-lbl{position:absolute;bottom:.62rem;left:.72rem;z-index:2;font-size:.66rem;color:rgba(255,255,255,.68);letter-spacing:.1em;text-transform:uppercase;opacity:0;transition:opacity .3s}
.gi:hover .gi-lbl{opacity:1}
.g1{grid-column:1/5;grid-row:1/3}.g2{grid-column:5/9;grid-row:1/2}
.g3{grid-column:9/13;grid-row:1/3}.g4{grid-column:5/7;grid-row:2/3}
.g5{grid-column:7/9;grid-row:2/3}.g6{grid-column:1/4;grid-row:3/4}
.g7{grid-column:4/8;grid-row:3/4}.g8{grid-column:8/13;grid-row:3/4}
/* restaurant photo on the big tiles */
.g1 .gphoto,.g3 .gphoto{position:absolute;inset:0;z-index:0}
.g1 .gphoto img,.g3 .gphoto img{width:100%;height:100%;object-fit:cover;opacity:.65;transition:opacity .3s;display:block}
.g1:hover .gphoto img,.g3:hover .gphoto img{opacity:.82}
.g1 .gi-bg,.g3 .gi-bg{position:relative;z-index:1;background:transparent!important}
.g1 .gi-bg{background:linear-gradient(135deg,#3d0e14,#6b1c22)!important}
.g3 .gi-bg{background:linear-gradient(135deg,#2a1a05,#4a2e08)!important}
.g2  .gi-bg{background:linear-gradient(135deg,#3d2008,#6b3810)}
.g4  .gi-bg{background:linear-gradient(135deg,#1c1a10,#302e18)}
.g5  .gi-bg{background:linear-gradient(135deg,#0e2010,#1a381a)}
.g6  .gi-bg{background:linear-gradient(135deg,#300815,#550e20)}
.g7  .gi-bg{background:linear-gradient(135deg,#1a1020,#2e1c38)}
.g8  .gi-bg{background:linear-gradient(135deg,#2a1005,#4a1e08)}
@media(max-width:768px){
  .ggrid{grid-template-columns:1fr 1fr;grid-template-rows:auto}
  .g1,.g2,.g3,.g4,.g5,.g6,.g7,.g8{grid-column:auto;grid-row:auto;height:145px}
}

/* TESTIMONIALS */
.testi{background:var(--saff-pale)}
.tgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(286px,1fr));gap:1.35rem;margin-top:2.4rem}
.tc{background:#fff;border:1px solid var(--border);border-radius:6px;padding:1.65rem;position:relative;transition:box-shadow .3s}
.tc:hover{box-shadow:var(--shad)}
.tc.dk{background:var(--burg);border-color:rgba(232,130,26,.24)}
.tc.dk .tt{color:rgba(250,246,240,.63)}
.tc.dk .tn{color:#fff}
.tc.dk .tm2{color:rgba(250,246,240,.33)}
.tqm{font-family:'Playfair Display',serif;font-size:4.2rem;line-height:0;color:var(--saff);opacity:.2;display:block;margin-bottom:.95rem}
.tst{color:var(--saff);font-size:.8rem;margin-bottom:.65rem;letter-spacing:.1em}
.tt{font-size:.88rem;line-height:1.77;color:var(--tm);font-style:italic;margin-bottom:1.15rem}
.tau{display:flex;align-items:center;gap:.82rem}
.tav{
  width:35px;height:35px;border-radius:50%;
  background:linear-gradient(135deg,var(--saff),var(--burg));
  display:flex;align-items:center;justify-content:center;
  font-weight:700;color:#fff;font-size:.8rem;flex-shrink:0;
}
.tn{font-weight:600;font-size:.82rem;color:var(--td)}
.tm2{font-size:.68rem;color:var(--tl);margin-top:.1rem}
.rbox{
  display:flex;align-items:center;gap:3rem;flex-wrap:wrap;
  background:linear-gradient(135deg,var(--burg),var(--burg-d));
  border-radius:6px;padding:2rem 2.4rem;margin-top:2.4rem;
  border:1px solid rgba(232,130,26,.2);
}
.rbig{font-family:'Playfair Display',serif;font-size:4.8rem;font-weight:700;color:var(--saff-lt);line-height:1}
.rst{font-size:1.2rem;color:var(--saff);letter-spacing:.1em}
.rcnt{font-size:.76rem;color:rgba(250,246,240,.42);margin-top:.2rem}
.rbars{flex:1;min-width:195px}
.brow{display:flex;align-items:center;gap:.68rem;margin-bottom:.42rem}
.bl{font-size:.7rem;color:rgba(250,246,240,.55);font-weight:500;width:10px}
.bt{flex:1;height:5px;background:rgba(255,255,255,.1);border-radius:3px;overflow:hidden}
.bf{height:100%;background:linear-gradient(to right,var(--saff),var(--spice));border-radius:3px}
